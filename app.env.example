# RiceMoto Flutter app — local environment config
# Copy this file to app.env and fill in your values.
# app.env is gitignored (never commit real values).

# LAN IP of the machine running the backend (npm run start:dev).
# Find it with: ipconfig → "IPv4 Address", e.g. 192.168.1.12
# Android emulator: leave empty → auto-uses 10.0.2.2
# iOS Simulator: leave empty → auto-uses localhost
API_HOST=192.168.1.10

# Backend port (default 3000, matches RiceMoto_Backend .env PORT)
API_PORT=3000
