    <!-- Terms & Privacy -->
    <string name="terms_updated">Cập nhật lần cuối: @date</string>
    <string name="terms_s1_title">1. Giới thiệu</string>
    <string name="terms_s1_body">Chào mừng bạn đến với RiceMoto. Khi sử dụng ứng dụng, bạn đồng ý với các điều khoản dưới đây. Vui lòng đọc kỹ trước khi tiếp tục.</string>
    <string name="terms_s2_title">2. Tài khoản</string>
    <string name="terms_s2_body">Bạn chịu trách nhiệm bảo mật thông tin đăng nhập và mọi hoạt động phát sinh từ tài khoản của mình. Vui lòng thông báo cho chúng tôi nếu phát hiện truy cập trái phép.</string>
    <string name="terms_s3_title">3. Quyền riêng tư &amp; Dữ liệu</string>
    <string name="terms_s3_body">Dữ liệu chi phí, hóa đơn và thông tin xe của bạn được dùng để cung cấp dịch vụ và tính năng thống kê. Chúng tôi không bán dữ liệu cá nhân của bạn cho bên thứ ba.</string>
    <string name="terms_s4_title">4. Thanh toán &amp; Premium</string>
    <string name="terms_s4_body">Gói Premium được thanh toán qua cửa hàng ứng dụng và tự động gia hạn cho đến khi bạn hủy. Bạn có thể hủy bất cứ lúc nào trong phần cài đặt tài khoản của cửa hàng.</string>
    <string name="terms_s5_title">5. Liên hệ</string>
    <string name="terms_s5_body">Mọi thắc mắc về điều khoản hoặc quyền riêng tư, vui lòng liên hệ support@ricemoto.app.</string>

