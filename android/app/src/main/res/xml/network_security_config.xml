<?xml version="1.0" encoding="utf-8"?>
<!--
  Production config: HTTPS only (no cleartext).
  Debug builds override this via android/app/src/debug/AndroidManifest.xml
  which sets usesCleartextTraffic="true" — so no IP needs to be listed here.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
